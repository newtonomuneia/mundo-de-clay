"use client";

import { useEffect, useState } from "react";
import { supabase } from "@/lib/supabase";
import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
} from "@/components/ui/dialog";
import { toast } from "sonner";

// ============================================================
// Tipos
// ============================================================
interface Premissa {
  id: string;
  premissa: string;
  padrao_tematico: string;
  padrao_numero: number;
  fonte: string;
  upvotes: number;
  status: "disponível" | "em_uso" | "publicada" | "rejeitada" | "descartada";
  video_id: string | null;
  reddit_url: string | null;
  created_at: string;
}

interface Video {
  id: string;
  premissa_id: string;
  modulo_atual: string | null;
  status: string | null;
  titulo: string | null;
}

interface PremissaComVideo extends Premissa {
  video?: Video | null;
}

// ============================================================
// Mapeamento módulo → label/cor do badge de etapa
// ============================================================
const ETAPAS: Record<
  string,
  { label: string; variant: "default" | "secondary" | "outline" | "destructive"; cor: string }
> = {
  disponivel: { label: "Disponível", variant: "outline", cor: "bg-slate-500/20 text-slate-300" },
  "01": { label: "Coleta", variant: "secondary", cor: "bg-slate-500/20 text-slate-300" },
  "02": { label: "Roteiro", variant: "secondary", cor: "bg-blue-500/20 text-blue-300" },
  "03": { label: "Direção", variant: "secondary", cor: "bg-indigo-500/20 text-indigo-300" },
  "04": { label: "Imagens", variant: "secondary", cor: "bg-purple-500/20 text-purple-300" },
  "05": { label: "Narração", variant: "secondary", cor: "bg-pink-500/20 text-pink-300" },
  "06": { label: "Efeitos", variant: "secondary", cor: "bg-orange-500/20 text-orange-300" },
  "07": { label: "Animação", variant: "secondary", cor: "bg-amber-500/20 text-amber-300" },
  "08": { label: "Montagem", variant: "secondary", cor: "bg-yellow-500/20 text-yellow-300" },
  "09": { label: "Publicação", variant: "secondary", cor: "bg-lime-500/20 text-lime-300" },
  publicada: { label: "Publicada", variant: "default", cor: "bg-green-500/20 text-green-300" },
  descartada: { label: "Descartada", variant: "outline", cor: "bg-zinc-500/20 text-zinc-400" },
};
function getRotaVideo(modulo: string | null | undefined): string {
  const m = (modulo || "").padStart(2, "0");
  if (m === "02") return "roteiro";
  if (m === "03" || m === "04") return "imagens";
  if (m === "05") return "narracao";
  return "preview";
}
function getEtapa(p: PremissaComVideo): { label: string; cor: string } {
  if (p.status === "descartada") return ETAPAS.descartada;
  if (p.status === "publicada") return ETAPAS.publicada;
  if (!p.video || !p.video.modulo_atual) return ETAPAS.disponivel;
  const mod = p.video.modulo_atual.padStart(2, "0");
  return ETAPAS[mod] || ETAPAS.disponivel;
}

// ============================================================
// Página
// ============================================================
export default function PremissasPage() {
  const [premissas, setPremissas] = useState<PremissaComVideo[]>([]);
  const [loading, setLoading] = useState(true);
  const [mostrarDescartadas, setMostrarDescartadas] = useState(false);
  const [mostrarPublicadas, setMostrarPublicadas] = useState(false);

  // Modal de cancelamento
  const [cancelarTarget, setCancelarTarget] = useState<PremissaComVideo | null>(null);
  const [cancelando, setCancelando] = useState(false);

  // ----------------------------------------------------------
  // Fetch
  // ----------------------------------------------------------
  useEffect(() => {
    fetchData();

    // Realtime: refetch quando premissas ou videos mudarem
    const channel = supabase
      .channel("premissas-feed")
      .on("postgres_changes", { event: "*", schema: "public", table: "premissas" }, fetchData)
      .on("postgres_changes", { event: "*", schema: "public", table: "videos" }, fetchData)
      .subscribe();

    return () => {
      supabase.removeChannel(channel);
    };
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  async function fetchData() {
    const { data: pData, error: pErr } = await supabase
      .from("premissas")
      .select("*")
      .order("upvotes", { ascending: false });

    if (pErr) {
      toast.error("Erro ao carregar premissas");
      setLoading(false);
      return;
    }

    // Buscar videos relacionados (uma única query)
    const premissaIds = (pData || []).filter((p) => p.video_id).map((p) => p.video_id);
    let videosMap: Record<string, Video> = {};
    if (premissaIds.length > 0) {
      const { data: vData } = await supabase
        .from("videos")
        .select("id,premissa_id,modulo_atual,status,titulo")
        .in("id", premissaIds);
      if (vData) {
        videosMap = Object.fromEntries(vData.map((v: Video) => [v.id, v]));
      }
    }

    const enriched: PremissaComVideo[] = (pData || []).map((p: Premissa) => ({
      ...p,
      video: p.video_id ? videosMap[p.video_id] || null : null,
    }));

    setPremissas(enriched);
    setLoading(false);
  }

  // ----------------------------------------------------------
  // Filtro + contadores
  // ----------------------------------------------------------
  const premissasVisiveis = premissas.filter((p) => {
    if (p.status === "rejeitada") return false;
    if (p.status === "descartada" && !mostrarDescartadas) return false;
    if (p.status === "publicada" && !mostrarPublicadas) return false;
    return true;
  });

  const totais = {
    todas: premissas.length,
    disponiveis: premissas.filter((p) => p.status === "disponível").length,
    em_producao: premissas.filter((p) => p.status === "em_uso").length,
    publicadas: premissas.filter((p) => p.status === "publicada").length,
    descartadas: premissas.filter((p) => p.status === "descartada").length,
  };

  // ----------------------------------------------------------
  // Ações
  // ----------------------------------------------------------
  async function selecionar(premissa_id: string) {
    toast.info("Disparando geração de roteiro...");
    try {
      const res = await fetch(`/api/webhook?path=premissa/selecionar`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ premissa_id }),
      });
      const data = await res.json();
      if (data.success || data.video_id) {
        toast.success("Roteiro em geração");
      } else {
        toast.error(data.erro || "Erro ao selecionar");
      }
    } catch {
      toast.error("Erro de conexão com n8n");
    }
    fetchData();
  }

  async function descartar(premissa_id: string) {
    try {
      const res = await fetch(`/api/webhook?path=premissa/descartar`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ premissa_id }),
      });
      const data = await res.json();
      if (data.success) {
        toast.success("Premissa descartada");
      } else {
        toast.error(data.erro || "Erro ao descartar");
      }
    } catch {
      toast.error("Erro de conexão");
    }
    fetchData();
  }

  async function restaurar(premissa_id: string) {
    try {
      const res = await fetch(`/api/webhook?path=premissa/restaurar`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ premissa_id }),
      });
      const data = await res.json();
      if (data.success) {
        toast.success("Premissa restaurada");
      } else {
        toast.error(data.erro || "Erro ao restaurar");
      }
    } catch {
      toast.error("Erro de conexão");
    }
    fetchData();
  }

  async function confirmarCancelar() {
    if (!cancelarTarget) return;
    setCancelando(true);
    try {
      const res = await fetch(`/api/webhook?path=premissa/cancelar`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ premissa_id: cancelarTarget.id }),
      });
      const data = await res.json();
      if (data.success) {
        toast.success("Cancelamento iniciado. Aguarde alguns segundos.");
        setTimeout(fetchData, 3000);
      } else {
        toast.error(data.erro || "Erro ao cancelar");
      }
    } catch {
      toast.error("Erro de conexão");
    }
    setCancelando(false);
    setCancelarTarget(null);
  }

  // ----------------------------------------------------------
  // Render
  // ----------------------------------------------------------
  if (loading) {
    return (
      <div className="p-8 text-center text-muted-foreground">Carregando premissas...</div>
    );
  }

  return (
    <div className="max-w-6xl mx-auto p-6 space-y-6">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-3xl font-bold text-foreground">Premissas</h1>
          <p className="text-sm text-muted-foreground mt-1">
            {totais.disponiveis} disponíveis · {totais.em_producao} em produção ·{" "}
            {totais.publicadas} publicadas · {totais.descartadas} descartadas
          </p>
        </div>
        <div className="flex gap-2">
          <Button
            variant={mostrarDescartadas ? "default" : "outline"}
            size="sm"
            onClick={() => setMostrarDescartadas(!mostrarDescartadas)}
          >
            {mostrarDescartadas ? "Ocultar" : "Mostrar"} descartadas
          </Button>
          <Button
            variant={mostrarPublicadas ? "default" : "outline"}
            size="sm"
            onClick={() => setMostrarPublicadas(!mostrarPublicadas)}
          >
            {mostrarPublicadas ? "Ocultar" : "Mostrar"} publicadas
          </Button>
        </div>
      </div>

      {/* Lista */}
      {premissasVisiveis.length === 0 ? (
        <div className="text-center text-muted-foreground py-12">Nenhuma premissa para exibir.</div>
      ) : (
        <div className="space-y-3">
          {premissasVisiveis.map((p) => {
            const etapa = getEtapa(p);
            const temVideo = !!p.video;
            const ehDescartada = p.status === "descartada";
const ehDisponivel = !temVideo && p.status !== "descartada" && p.status !== "publicada";
const emProducao = temVideo && p.status !== "publicada" && p.status !== "descartada";
console.log("DEBUG", p.premissa, { status: p.status, temVideo, emProducao, video: p.video });
            return (
              <Card
                key={p.id}
                className={ehDescartada ? "opacity-60" : ""}
              >
                <CardContent className="p-4">
                  <div className="flex items-start justify-between gap-4">
                    {/* Conteúdo principal */}
                    <div className="flex-1 min-w-0">
                      <div className="flex items-center gap-2 mb-2 flex-wrap">
                        <span className={`text-xs px-2 py-0.5 rounded font-medium ${etapa.cor}`}>
                          {etapa.label}
                        </span>
                        <Badge variant="outline" className="text-xs">
                          Padrão {p.padrao_numero}: {p.padrao_tematico}
                        </Badge>
                        <span className="text-xs text-muted-foreground">
                          ▲ {p.upvotes} · {p.fonte}
                        </span>
                      </div>

                      <p className="text-sm text-foreground leading-relaxed">{p.premissa}</p>

                      {p.video?.titulo && (
                        <p className="text-xs text-muted-foreground mt-2">
                          Vídeo: <span className="font-medium">{p.video.titulo}</span>
                        </p>
                      )}
                    </div>

                    {/* Ações */}
                    <div className="flex flex-col gap-2 shrink-0">
                      {ehDisponivel && (
                        <>
                          <Button size="sm" onClick={() => selecionar(p.id)}>
                            Selecionar
                          </Button>
                          <Button
                            size="sm"
                            variant="outline"
                            onClick={() => descartar(p.id)}
                          >
                            Descartar
                          </Button>
                        </>
                      )}

                      {emProducao && p.video && (
                        <>

                            Abrir
                          </Button>
                          <Button
                            size="sm"
                            variant="destructive"
                            onClick={() => setCancelarTarget(p)}
                          >
                            Cancelar
                          </Button>
                        </>
                      )}

                      {ehDescartada && (
                        <Button
                          size="sm"
                          variant="outline"
                          onClick={() => restaurar(p.id)}
                        >
                          Restaurar
                        </Button>
                      )}

                      {p.status === "publicada" && p.video && (
<Button size="sm" variant="outline" onClick={() => window.location.href = `/${getRotaVideo(p.video!.modulo_atual)}/${p.video!.id}`}>
                          Ver
                        </Button>
                      )}
                    </div>
                  </div>
                </CardContent>
              </Card>
            );
          })}
        </div>
      )}

      {/* Modal de confirmação de Cancelar */}
      <Dialog open={!!cancelarTarget} onOpenChange={(open) => !open && setCancelarTarget(null)}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Cancelar produção?</DialogTitle>
            <DialogDescription className="space-y-2 pt-2">
              <span className="block">Esta ação é irreversível e vai deletar:</span>
              <ul className="list-disc list-inside text-sm space-y-1 text-foreground">
                <li>Todos os arquivos do storage (imagens, narrações, efeitos, trilhas, animações, vídeo final)</li>
                <li>Todas as cenas do vídeo</li>
                <li>Todas as opções de roteiro</li>
                <li>O registro do vídeo</li>
              </ul>
              <span className="block pt-2 text-foreground">
                A premissa volta para <b>disponível</b> e pode ser selecionada novamente.
              </span>
              {cancelarTarget && (
                <span className="block mt-3 p-2 bg-muted rounded text-xs italic text-muted-foreground">
                  &ldquo;{cancelarTarget.premissa}&rdquo;
                </span>
              )}
            </DialogDescription>
          </DialogHeader>
          <DialogFooter>
            <Button variant="outline" onClick={() => setCancelarTarget(null)} disabled={cancelando}>
              Voltar
            </Button>
            <Button variant="destructive" onClick={confirmarCancelar} disabled={cancelando}>
              {cancelando ? "Cancelando..." : "Sim, deletar tudo"}
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </div>
  );
}
